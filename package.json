{
  "name": "glyphit3d",
  "version": "0.0.1",
  "description": "Glyphit3D — glyph-constrained 3D renderer — 3D G-buffers matched to a continuous-coverage font atlas with closed-form two-color least squares",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "cli": "tsx src/cli.ts",
    "e2e": "tsx test-e2e/demo.spec.ts",
    "dev": "vite --config web/vite.config.ts",
    "build": "vite build --config web/vite.config.ts",
    "profiles": "tsx scripts/export-atlas.ts"
  },
  "keywords": [
    "ascii",
    "ansi",
    "3d",
    "glyph",
    "terminal",
    "renderer",
    "chafa"
  ],
  "author": "Jahn (Dev-Jahn)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dev-Jahn/glyphit3d.git"
  },
  "type": "module",
  "private": "true",
  "devDependencies": {
    "@types/fontkit": "^2.0.9",
    "@types/node": "^26.1.0",
    "playwright": "^1.61.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "fontkit": "^2.0.4",
    "three": "^0.185.1"
  }
}
